# ======================================
# FredoCloud Environment Variables Template
# ======================================
# Copy this file and fill in the actual values
# You will populate these via CLI before running migrations/seed

# ======================================
# BACKEND (apps/api/.env)
# ======================================

# PostgreSQL Connection
DATABASE_URL=postgresql://user:password@host:5432/fredocloud_db

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Configuration (Nodemailer - Gmail)
# Leave blank to disable email notifications
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your_app_password_here

# Server Port
PORT=4000

# ======================================
# FRONTEND (apps/web/.env.local)
# ======================================

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# ======================================
# TESTING (Optional - apps/api/.env.test)
# ======================================

TEST_DATABASE_URL=postgresql://user:password@host:5432/fredocloud_test

# ======================================
# NOTES
# ======================================
# 1. Generate JWT secrets with:
#    openssl rand -base64 32
#
# 2. For Cloudinary:
#    - Sign up at https://cloudinary.com
#    - Get credentials from Dashboard > Settings
#
# 3. For Gmail with Nodemailer:
#    - Enable 2FA on your Gmail account
#    - Create an App Password: https://support.google.com/accounts/answer/185833
#    - Use the 16-character password in EMAIL_PASS
#
# 4. On Railway:
#    - PostgreSQL addon injects DATABASE_URL automatically
#    - Set remaining vars in Railway dashboard > Variables
#    - Frontend service needs NEXT_PUBLIC_* vars
#    - Backend service needs all other vars
#
# 5. Local development:
#    - Backend: cp .env.example apps/api/.env && fill values
#    - Frontend: cp .env.example apps/web/.env.local && fill values
#
# 6. If EMAIL_USER or EMAIL_PASS not set:
#    - Email notifications gracefully disabled (no error)
#    - All send functions become no-ops
#    - Server logs a warning at startup

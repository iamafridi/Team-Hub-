{
  "name": "@team-hub/api",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "npx prisma db push --accept-data-loss && node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "prisma generate",
    "postinstall": "prisma generate",
    "test": "jest --runInBand --forceExit --detectOpenHandles",
    "migrate": "prisma migrate deploy",
    "seed": "node prisma/seed.js",
    "lint": "eslint src"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@team-hub/shared": "*",
    "cloudinary": "^1.33.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^6.7.0",
    "firebase-admin": "^13.8.0",
    "helmet": "^7.0.0",
    "json2csv": "^5.0.7",
    "morgan": "^1.10.0",
    "multer": "1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.0",
    "prisma": "^5.0.0",
    "socket.io": "^4.6.0",
    "swagger-jsdoc": "^6.2.0",
    "swagger-ui-express": "^5.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ]
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
